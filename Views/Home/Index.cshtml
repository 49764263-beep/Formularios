@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Farmulario</h1>
</div>
<form action='@Url.Action("GuardarDatos", "Home")' method='POST' enctype="multipart/form-data"> 
    Nombre: <input type = "text" name = "Nombre" placeholder="Ingresar Nombre"/><br>
    Edad: <input type = "number" name = "Edad" placeholder="Ingresar Edad"/><br>
    DNI: <input type = "number" name = "DNI" placeholder="Ingresar DNI"/><br>
    ¿Actualmente trabaja? 
    <input type = "radio" name = "Trabajando" value="true">Si
    <input type = "radio" name = "Trabajando" value="false">No <br>
    Tipo de empleo:
    <select name="tipo">
        <option value="1"></option>
        <option value="2">Relación de dependencia</option>
        <option value="3">Monotributista</option>
        <option value="4">Autónomo</option>
        <option value="5">Desempleado</option>
    </select> <br>
    Ingreso mensual: <input type = "number" name = "Ingreso" placeholder="Ingresar Monto"/> <br>
    ¿Posee deudas?
    <input type = "radio" name = "ConDeudas" value="true">Si
    <input type = "radio" name = "ConDeudas" value="false">No <br>
    Tipo de deudas:
    <input type="checkbox" name="Deduda" value="1">No tengo ninguna deuda
    <input type="checkbox" name="Deduda" value="2">Tarjeta de crédito
    <input type="checkbox" name="Deduda" value="3">Préstamo bancario
    <input type="checkbox" name="Deduda" value="4">Préstamo Informal <br>
    Monto solicitado: <input type = "number" name = "Monto" placeholder="Ingresar Monto"/> <br>
    Plazo de devolución:
    <select name="tipo">
        <option value="1"></option>
        <option value="2">6 meses</option>
        <option value="3">12 meses</option>
        <option value="4">24 meses</option>
    </select> <br>
    ¿Acepta Terminos y Condiciones?
    <input type = "radio" name = "Terminos" value="true">Si
    <input type = "radio" name = "Terminos" value="false">No <br>
    <a href="https://policies.google.com/terms?hl=es" target="_blank">Ver Terrminos y Condiciones</a><br>
    <input type="submit" value="Enviar">
    <input type="reset" value="resetear">
</form>
